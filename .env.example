# --- Frodobots SDK server env (used by the SDK's own `hypercorn main:app`, NOT this client) ---
# Get token at https://my.frodobots.com/owner/settings after activating a bot (or a challenge allocation).
SDK_API_TOKEN=
BOT_SLUG=
CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
MISSION_SLUG=            # set to enable the Missions API (start-mission / checkpoints)

# --- this client / follower ---
SDK_BASE_URL=http://localhost:8000
CHECKPOINT_RADIUS_M=5
CRUISE=0.6
KP_ANG=1.5
ALIGN_DEG=20
LOOP_HZ=5

# real-bot heading calibration: heading_deg = HEADING_SIGN * orientation * HEADING_SCALE + HEADING_OFFSET
# default assumes orientation is 0..255 over 360deg; VERIFY by driving straight (see README).
HEADING_SCALE=1.4117647   # 360/255
HEADING_OFFSET=0
HEADING_SIGN=1

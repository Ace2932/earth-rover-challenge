# --- Frodobots SDK server env (used by the SDK's own `hypercorn main:app`, NOT this client) ---
# Get token at https://my.frodobots.com/owner/settings after activating a bot (or a challenge allocation).
SDK_API_TOKEN=
BOT_SLUG=
CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
MISSION_SLUG=            # set to enable the Missions API (start-mission / checkpoints)

# --- this client / follower (all Config fields are UPPERCASE env overrides) ---
SDK_BASE_URL=http://localhost:8000
CHECKPOINT_RADIUS_M=5    # gate to start asking the server "reached?"
CRUISE=0.6              # forward throttle when aligned (0..1)
KP_ANG=1.5             # steering gain
ALIGN_DEG=20           # within this heading error -> full cruise
DEADBAND_DEG=3         # ignore tiny errors (anti-jitter)
APPROACH_M=6           # start slowing within this distance of a waypoint
MIN_CREEP=0.25         # floor on approach-slowdown factor
MAX_DANG=0.35          # max angular change per step (slew limit, anti-oscillation)
LOOP_HZ=5
STUCK_S=20             # no progress this long -> declare stuck and stop
MAX_RUNTIME_S=3600
HEADING_MIN_MOVE_M=0.7  # move at least this far to trust GPS course over the magnetometer

# magnetometer fallback only (used when moving < HEADING_MIN_MOVE_M):
# heading_deg = HEADING_SIGN * orientation * HEADING_SCALE + HEADING_OFFSET
# NOTE: with GPS-course fusion you rarely need this perfect — it's the slow-speed fallback.
HEADING_SCALE=1.4117647   # 360/255
HEADING_OFFSET=0
HEADING_SIGN=1

# --- fake server only ---
FAKE_FAIL_RATE=0        # inject transient 503s at this rate to test client retry
